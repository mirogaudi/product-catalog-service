<?xml version="1.0"?>

<!DOCTYPE suppressions PUBLIC
    "-//Checkstyle//DTD SuppressionFilter Configuration 1.2//EN"
    "https://checkstyle.org/dtds/suppressions_1_2.dtd">

<suppressions>
    <suppress checks="JavadocPackage" files=".*"/>
    <suppress checks="JavadocType" files=".*"/>
    <suppress checks="JavadocMethod" files=".*"/>
    <suppress checks="JavadocVariable" files=".*"/>
    <suppress checks="DesignForExtension" files=".*"/>
    <suppress checks="FinalParameters" files=".*"/>
    <suppress checks="HideUtilityClassConstructor" files="ProductCatalogServiceApplication\.java"/>
    <suppress checks="MagicNumberCheck" files="(config|controller|domain)/.*"/>
    <suppress checks="LineLength" files=".*"/>
</suppressions>
